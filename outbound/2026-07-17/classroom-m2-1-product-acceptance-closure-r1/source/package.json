    "validate:classroom-handoff": "node --experimental-strip-types scripts/validate-classroom-handoff.mjs",
    "validate:classroom-overview": "node --experimental-strip-types scripts/validate-classroom-overview-r1.mjs",
    "validate:user-center": "node --experimental-strip-types scripts/validate-user-center-r0.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate"
