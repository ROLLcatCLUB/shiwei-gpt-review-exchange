    "validate:classroom-sequence-p1-1": "node --experimental-strip-types scripts/validate-classroom-presentation-sequence-p1-1.mjs",
    "test:classroom-handoff-r0-2": "node --experimental-strip-types --test tests/classroom-handoff-r0-2-hardening.test.mjs",
    "validate:classroom-handoff-r0-2": "node --experimental-strip-types scripts/validate-classroom-handoff-r0-2.mjs",
    "test:classroom-evolution-r0": "node --experimental-strip-types --test tests/contextual-lesson-evolution-r0.test.mjs",
